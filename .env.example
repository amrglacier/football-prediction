# ============================================================
# Football Prediction System - Environment Configuration
# Copy this file to .env and fill in your API keys.
# ============================================================

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=football
POSTGRES_PASSWORD=football_pass_change_me
POSTGRES_DB=football_prediction
DATABASE_URL=postgresql+asyncpg://football:football_pass_change_me@db:5432/football_prediction
SYNC_DATABASE_URL=postgresql://football:football_pass_change_me@db:5432/football_prediction

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Asia/Shanghai

# ============================================================
# Football Data API (choose one)
# ============================================================
# API-Football (RapidAPI) - Free tier: 100 requests/day
FOOTBALL_API_PROVIDER=api-football
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://api-football-v1.p.rapidapi.com/v3

# SportMonks - Alternative
# FOOTBALL_API_PROVIDER=sportmonks
# SPORTMONKS_API_KEY=your_sportmonks_key_here

# ============================================================
# AI Model API Keys
# Free / low-cost providers are marked with [FREE]
# ============================================================

# --- DeepSeek [FREE tier: limited free credits] ---
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Qwen / 通义千问 [FREE: DashScope free quota] ---
QWEN_API_KEY=your_qwen_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Kimi / Moonshot [FREE tier: 15 RPM] ---
KIMI_API_KEY=your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# --- ERNIE / 文心一言 [FREE: Qianfan free quota] ---
ERNIE_API_KEY=your_ernie_key_here
ERNIE_SECRET_KEY=your_ernie_secret_key_here

# --- Gemini [FREE tier: 15 RPM, 1500 RPD] ---
GEMINI_API_KEY=your_gemini_key_here

# --- Claude / Anthropic [Paid - optional] ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- OpenAI / GPT-4o [Paid - optional] ---
OPENAI_API_KEY=your_openai_key_here

# --- Groq / Llama [FREE: very generous tier] ---
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ============================================================
# System Parameters (defaults from spec)
# ============================================================
DELTA_T=60
VOLATILITY_THRESHOLD=0.15
LEARNING_RATE=0.05
MAX_HISTORY=5
MAX_CONCURRENT_PREDICTIONS=10
